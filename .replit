language = "c"
run = "gcc -o labrabota2-1 /home/runner/workspace/src/main.c && ./labrabota2-1"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && gcc -o hello src/hello.c && ./hello"

[workflows.workflow.metadata]
outputType = "console"

[nix]
packages = ["nano", "run"]
